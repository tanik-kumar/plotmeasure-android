<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.BiharMapMeasure" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/terracotta_600</item>
        <item name="colorPrimaryVariant">@color/terracotta_700</item>
        <item name="colorSecondary">@color/forest_600</item>
        <item name="colorSecondaryVariant">@color/forest_700</item>
        <item name="colorSurface">@color/paper_0</item>
        <item name="android:colorBackground">@color/sand_050</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorOnSecondary">@android:color/white</item>
        <item name="colorOnSurface">@color/ink_900</item>
        <item name="colorOnBackground">@color/ink_900</item>
        <item name="android:statusBarColor">@color/sand_050</item>
        <item name="android:navigationBarColor">@color/sand_050</item>
        <item name="android:windowBackground">@drawable/bg_screen</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.BiharMapMeasure.Medium</item>
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.BiharMapMeasure.Small</item>
        <item name="materialButtonStyle">@style/Widget.BiharMapMeasure.Button</item>
        <item name="materialButtonOutlinedStyle">@style/Widget.BiharMapMeasure.Button.Outlined</item>
        <item name="materialCardViewStyle">@style/Widget.BiharMapMeasure.Card</item>
    </style>

    <style name="ShapeAppearance.BiharMapMeasure.Small" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="ShapeAppearance.BiharMapMeasure.Medium" parent="ShapeAppearance.MaterialComponents.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>

    <style name="Widget.BiharMapMeasure.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">18dp</item>
        <item name="backgroundTint">@color/terracotta_600</item>
        <item name="rippleColor">@color/terracotta_200</item>
        <item name="android:textColor">@android:color/white</item>
    </style>

    <style name="Widget.BiharMapMeasure.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">18dp</item>
        <item name="backgroundTint">@color/paper_glass_strong</item>
        <item name="strokeColor">@color/sand_300</item>
        <item name="android:textColor">@color/ink_900</item>
    </style>

    <style name="Widget.BiharMapMeasure.Button.CompactOutlined" parent="Widget.BiharMapMeasure.Button.Outlined">
        <item name="android:minHeight">40dp</item>
        <item name="cornerRadius">16dp</item>
    </style>

    <style name="Widget.BiharMapMeasure.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">24dp</item>
        <item name="strokeColor">@color/sand_300</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardElevation">0dp</item>
    </style>
</resources>
